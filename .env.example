# IndustrialMind environment variables
# Copy this to .env and fill in your keys

GROQ_API_KEY=your-groq-api-key-here

# Backward-compatible alias accepted by the app as well:
# ANTHROPIC_API_KEY=your-groq-api-key-here

# Optional overrides (defaults are set in config.py)
# CHROMA_URL=https://your-chroma-service.up.railway.app
# GROQ_MODEL=llama-3.3-70b-versatile
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=industrialmind
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000
